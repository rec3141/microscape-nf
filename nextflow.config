// ============================================================================
// Microscape Amplicon Pipeline - Nextflow Configuration
// ============================================================================

// Default parameters (override via CLI: --param_name value)
params {
    // Help
    help            = false

    // Required (one of input or samplesheet)
    input           = null      // Directory containing demultiplexed *.fastq.gz reads
    samplesheet     = null      // CSV with columns: sample_id, run, plate_id, r1_path, r2_path, primer_pair
    primers         = null      // Primer FASTA file (or 'auto' to select by filename prefix)

    // Output
    outdir          = "results"
    store_dir       = null      // Persistent cache dir (opt-in)

    // Language: 'R' or 'python' (controls merge, filter, taxonomy, viz scripts)
    lang            = 'python'
    // Denoise engine: 'R' or 'python' (papa2 — byte-identical to R dada2, no R dependency)
    // null = follow lang setting
    denoise_engine  = null

    // Demultiplexing (optional — skip if reads are already demultiplexed)
    run_demultiplex = false
    forward_bcs     = null      // Forward barcode file for Mr_Demuxy
    reverse_bcs     = null      // Reverse barcode file for Mr_Demuxy

    // Primer removal
    skip_primer_removal = false // Skip if input is already trimmed
    primer_error_rate = 0.12    // Cutadapt max error rate
    primer_auto     = true      // Auto-select primer file by filename prefix (16S/18S/ITS)
    primers_fwd     = null      // User-supplied forward primer FASTA (overrides auto)
    primers_rev     = null      // User-supplied reverse primer FASTA (overrides auto)
    primers_fwd_bac = "${projectDir}/primers/fwd-bac.fa"
    primers_rev_bac = "${projectDir}/primers/rev-bac.fa"
    primers_fwd_euk = "${projectDir}/primers/fwd-euk.fa"
    primers_rev_euk = "${projectDir}/primers/rev-euk.fa"
    primers_fwd_its = "${projectDir}/primers/fwd-its.fa"
    primers_rev_its = "${projectDir}/primers/rev-its.fa"

    // Quality filtering
    auto_trim       = true      // Auto-detect truncation lengths from quality profiles
    auto_trim_min_quality = 25  // Min rolling median Q for auto-trim
    maxEE           = 2         // Max expected errors per read
    truncQ          = 2         // Truncate at first base with quality <= truncQ (dada2 default: 2)
    maxN            = 0         // Max Ns allowed (dada2 default: 0)
    truncLen_fwd    = 0         // Truncate forward reads (0 = auto, or set explicitly)
    truncLen_rev    = 0         // Truncate reverse reads (0 = auto, or set explicitly)
    min_overlap     = 12        // Minimum overlap for merging paired reads (dada2 default)

    // Merge and QC filtering
    min_seq_length  = 50        // Remove sequences shorter than this
    min_reads       = 100       // Minimum reads to keep a sample
    min_samples     = 2         // Minimum samples an ESV must appear in
    min_seqs        = 3         // Minimum total reads for an ESV

    // Taxonomy (Stage B)
    // Semicolon-separated database entries, each formatted as:
    //   name:path:Level1,Level2,...  (or name:path for default levels)
    // Example:
    //   --ref_databases "silva:/db/silva.fasta:Domain,Phylum,Class,Order,Family,Genus;pr2:/db/pr2.fasta:Domain,Supergroup,Division,Class,Order,Family,Genus,Species"
    ref_databases   = null

    // Phylogeny
    run_phylogeny   = false     // Build phylogenetic tree (slow for >10K ASVs)

    // Visualization
    build_viz_site  = false     // Build static Svelte site (requires Node.js)

    // Metadata (Stage C)
    metadata        = null      // Path to MIMARKS-compliant TSV/CSV metadata file
    sample_id_column = 'sample_name'  // Column in metadata matching sample IDs

    // Network
    min_prevalence  = 5         // Min samples an ASV must appear in for SparCC

    // Resources
    threads         = 8
    denoise_cpus    = 8
    denoise_memory  = '16 GB'
}

// ============================================================================
// Executor
// ============================================================================

def _sysMem = {
    try {
        def kb = new File('/proc/meminfo').readLines()
            .find { it.startsWith('MemTotal:') }?.split()?.getAt(1)?.toLong() ?: 8_000_000L
        return (kb * 1024L) as nextflow.util.MemoryUnit
    } catch (e) { return 8.GB }
}()

executor {
    $local {
        cpus   = Runtime.getRuntime().availableProcessors()
        memory = _sysMem
    }
}

// ============================================================================
// Conda configuration
// ============================================================================

conda {
    enabled       = true
    cacheDir      = "${projectDir}/conda-envs"
    useMamba      = true
    createTimeout = '60 min'
}

// ============================================================================
// Process resource labels
// ============================================================================

process {
    fair = true

    beforeScript = { def d = params.store_dir ?: params.outdir; "mkdir -p '${d}/pipeline_info' && echo '${task.process}\tSTART\t'\$(date -Iseconds) >> '${d}/pipeline_info/pipeline_timing.tsv'" }
    afterScript  = { def d = params.store_dir ?: params.outdir; "echo '${task.process}\tEND\t'\$(date -Iseconds)'\t'\${nxf_main_ret:-0} >> '${d}/pipeline_info/pipeline_timing.tsv'" }

    withLabel: 'process_low' {
        cpus   = 2
        memory = 4.GB
    }
    withLabel: 'process_medium' {
        cpus   = 4
        memory = 8.GB
    }
    withLabel: 'process_high' {
        cpus   = { params.denoise_cpus }
        memory = { params.denoise_memory }
    }

    errorStrategy = { task.attempt <= task.maxRetries ? 'retry' : 'ignore' }
    maxRetries    = 1
}

// ============================================================================
// Profiles
// ============================================================================

profiles {

    standard {
        process.executor = 'local'
    }

    test {
        params {
            outdir      = "test_results"
            denoise_cpus   = 4
            denoise_memory = '8 GB'
            threads     = 4
        }
        process {
            withLabel: 'process_high' {
                cpus   = 4
                memory = 8.GB
                time   = 2.h
            }
        }
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'default'
    }
}

// ============================================================================
// Reports and tracing
// ============================================================================

timeline {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/trace.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,rss,peak_rss'
}

dag {
    enabled   = true
    file      = "${params.store_dir ? params.store_dir : params.outdir}/pipeline_info/dag.html"
    overwrite = true
}

// ============================================================================
// Manifest
// ============================================================================

manifest {
    name            = 'microscape'
    author          = 'Microscape Pipeline'
    description     = 'Amplicon sequencing analysis: demultiplexing, DADA2 denoising, taxonomy, and visualization'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
